// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  agent
  broker
}

enum InvitationStatus {
  pending
  accepted
  declined
}

model User {
  id                 String           @id @default(uuid())
  email              String           @unique
  passwordHash       String
  role               Role
  surveyCompleted    Boolean          @default(false)
  emailVerified      Boolean          @default(false)
  emailVerifyToken   String?          @unique
  createdAt          DateTime         @default(now())
  brokerId           String?
  broker          User?            @relation("BrokerAgents", fields: [brokerId], references: [id])
  agents          User[]           @relation("BrokerAgents")
  surveyResponses    SurveyResponse[]
  scoreResult        ScoreResult?
  sentInvitations    BrokerInvitation[] @relation("BrokerSentInvitations")
}

model Question {
  id            String   @id
  text          String
  role          Role
  surveyType    String   @default("agent_intake")
  section       String   @default("1A")
  questionType  String   @default("likert")
  dimension     String?
  isScored      Boolean  @default(false)
  options       Json?
  required      Boolean  @default(true)
  sortOrder     Int
  storageTarget String   @default("raw_json")
  notes         String?
}

model SurveyResponse {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  answer     String
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model BrokerInvitation {
  id         String           @id @default(uuid())
  brokerId   String
  broker     User             @relation("BrokerSentInvitations", fields: [brokerId], references: [id])
  agentEmail String
  token      String           @unique @default(uuid())
  status     InvitationStatus @default(pending)
  createdAt  DateTime         @default(now())
  expiresAt  DateTime

  @@unique([brokerId, agentEmail])
}

model ScoreResult {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  surveyType       String
  autonomyScore    Float
  competenceScore  Float
  relatednessScore Float
  gritScore        Float
  selfRegScore     Float
  eiScore          Float
  overallScore     Float
  createdAt        DateTime @default(now())
}
